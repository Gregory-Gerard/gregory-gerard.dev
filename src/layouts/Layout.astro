---
export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <main class="min-h-screen bg-zinc-900 text-zinc-50">
      <div class="max-w-7xl mx-auto py-8 lg:py-16 px-4 lg:px-8">
        <slot />
      </div>
    </main>
  </body>
</html>
